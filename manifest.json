{
  "manifest_version": 3,
  "name": "Smart Analyst Export",
  "version": "1.5.0",
  "description": "Export PolyAI Smart Analyst chats to PDF or HTML",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://*.poly.ai/*", "https://*.polyai.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pdfmake.min.js", "vfs_fonts.js", "pdf-builder.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/analystexport_16.png",
    "48": "icons/analystexport_48.png",
    "128": "icons/analystexport_128.png"
  }
}
